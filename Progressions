<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Progression Master</title>
    <style>
        :root { 
            --bg: #121212; 
            --card: #1e1e1e; 
            --primary: #00d1b2; 
            --accent: #ffdd57; 
            --text: #f0f0f0; 
        }
        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
        
        body { 
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; 
            background: var(--bg); 
            color: var(--text); 
            margin: 0; 
            display: flex; 
            flex-direction: column; 
            height: 100vh;
        }

        header {
            background: #222;
            padding: 20px 15px;
            text-align: center;
            border-bottom: 2px solid var(--primary);
            flex-shrink: 0;
        }

        h1 { margin: 0; font-size: 1.5rem; letter-spacing: 1px; }
        h1 span { color: var(--primary); }

        .selector-container {
            padding: 20px 15px;
            background: #1a1a1a;
            flex-shrink: 0;
        }

        label { display: block; margin-bottom: 10px; color: #888; font-size: 0.9rem; text-transform: uppercase; }

        select {
            width: 100%;
            padding: 15px;
            background: #333;
            color: white;
            border: 1px solid #444;
            border-radius: 10px;
            font-size: 1.2rem;
            font-weight: bold;
            appearance: none;
            text-align: center;
        }

        #progs-list {
            flex: 1;
            overflow-y: auto;
            padding: 15px;
            padding-bottom: 40px;
            -webkit-overflow-scrolling: touch;
        }

        .prog-card {
            background: var(--card);
            border-radius: 15px;
            padding: 20px;
            margin-bottom: 15px;
            border-left: 5px solid var(--primary);
            box-shadow: 0 5px 15px rgba(0,0,0,0.3);
            animation: fadeIn 0.4s ease;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .prog-type {
            font-size: 0.75rem;
            color: var(--primary);
            text-transform: uppercase;
            font-weight: bold;
            margin-bottom: 5px;
        }

        .prog-chords {
            font-size: 1.8rem;
            font-weight: 800;
            color: white;
            margin: 10px 0;
            letter-spacing: 2px;
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
        }

        .chord-box {
            background: #2a2a2a;
            padding: 2px 10px;
            border-radius: 5px;
            border: 1px solid #444;
        }

        .prog-songs {
            font-size: 0.9rem;
            color: #aaa;
            line-height: 1.4;
            border-top: 1px solid #333;
            padding-top: 10px;
            margin-top: 10px;
        }

        .prog-songs b { color: var(--accent); }

        /* Scrollbar sottile per mobile */
        #progs-list::-webkit-scrollbar { width: 5px; }
        #progs-list::-webkit-scrollbar-thumb { background: #333; border-radius: 10px; }
    </style>
</head>
<body>

<header>
    <h1>PROG<span>MASTER</span></h1>
</header>

<div class="selector-container">
    <label>Choose your Key</label>
    <select id="key-select" onchange="generateProgressions()">
        <option value="C">C Major</option>
        <option value="G">G Major</option>
        <option value="D">D Major</option>
        <option value="A">A Major</option>
        <option value="E">E Major</option>
        <option value="B">B Major</option>
        <option value="F">F Major</option>
        <option value="Bb">Bb Major</option>
        <option value="Eb">Eb Major</option>
        <option value="Ab">Ab Major</option>
    </select>
</div>

<div id="progs-list">
    </div>

<script>
    const noteMap = {"C":0,"C#":1,"Db":1,"D":2,"D#":3,"Eb":3,"E":4,"F":5,"F#":6,"Gb":6,"G":7,"G#":8,"Ab":8,"A":9,"A#":10,"Bb":10,"B":11};
    const chromaticScale = ["C","Db","D","Eb","E","F","Gb","G","Ab","A","Bb","B"];

    const library = [
        { 
            name: "The Pop Punk / Modern Pop", 
            steps: [0, 7, 9, 5], 
            roman: "I - V - vi - IV",
            songs: "Let It Be (Beatles), Despacito, With or Without You (U2), I'm Yours (Jason Mraz)" 
        },
        { 
            name: "The Jazz 2-5-1", 
            steps: [2, 7, 0], 
            roman: "ii - V - I",
            songs: "Autumn Leaves, All The Things You Are, Summertime, Sunday Morning (Maroon 5)" 
        },
        { 
            name: "The 50s Doo-Wop", 
            steps: [0, 9, 5, 7], 
            roman: "I - vi - IV - V",
            songs: "Stand By Me, Every Breath You Take, Blue Moon, Last Kiss" 
        },
        { 
            name: "The Emotional / Epic", 
            steps: [9, 5, 0, 7], 
            roman: "vi - IV - I - V",
            songs: "Africa (Toto), Numb (Linkin Park), Apologize (OneRepublic), Hello (Adele)" 
        },
        { 
            name: "The Blues / Rock n' Roll", 
            steps: [0, 5, 7], 
            roman: "I - IV - V",
            songs: "Johnny B. Goode, Rock Around the Clock, Hound Dog" 
        },
        { 
            name: "The Sad / Sophisticated", 
            steps: [0, 4, 9, 5], 
            roman: "I - iii - vi - IV",
            songs: "Under The Bridge (RHCP), More Than Words (Extreme)" 
        }
    ];

    function generateProgressions() {
        const rootNote = document.getElementById('key-select').value;
        const rootVal = noteMap[rootNote];
        const container = document.getElementById('progs-list');
        container.innerHTML = "";

        library.forEach(item => {
            const chords = item.steps.map(step => {
                const note = chromaticScale[(rootVal + step) % 12];
                // Aggiungiamo 'm' per i gradi minori (ii, iii, vi)
                const isMinor = [2, 4, 9].includes(step); 
                return note + (isMinor ? "m" : "");
            });

            const card = document.createElement('div');
            card.className = 'prog-card';
            card.innerHTML = `
                <div class="prog-type">${item.name} (${item.roman})</div>
                <div class="prog-chords">
                    ${chords.map(c => `<div class="chord-box">${c}</div>`).join("")}
                </div>
                <div class="prog-songs">
                    <b>Famous Songs:</b> ${item.songs}
                </div>
            `;
            container.appendChild(card);
        });
    }

    // Initialize
    window.onload = generateProgressions;
</script>
</body>
</html>
